{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "sbt run and debug",
      "type": "shell",
      "isBackground": true,
      "command": "sbt -jvm-debug 5005 run",
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*welcome to sbt.*$",
          "endsPattern": "^.*running.*$"
        }
      }
    }
  ]
}